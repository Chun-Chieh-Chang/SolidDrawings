{
  "name": "cad-app",
  "version": "3.1.0-alpha",
  "private": true,
  "main": "out/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently \"npm run dev\" \"electron . --dev\"",
    "electron:build": "npm run build && npx tsc --project electron/tsconfig.json",
    "electron:start": "electron .",
    "electron:pack": "electron-builder --dir",
    "electron:dist": "electron-builder"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "gsap": "^3.15.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.184.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.3dbuilder.cad",
    "productName": "3D-Builder",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "fileAssociations": [
      {
        "ext": [
          "step",
          "stp"
        ],
        "name": "STEP File",
        "role": "Editor"
      },
      {
        "ext": [
          "iges",
          "igs"
        ],
        "name": "IGES File",
        "role": "Editor"
      },
      {
        "ext": [
          "stl"
        ],
        "name": "STL File",
        "role": "Editor"
      },
      {
        "ext": [
          "sldprt"
        ],
        "name": "SolidWorks Part",
        "role": "Editor"
      }
    ]
  }
}