# 3D-Builder 環境變數設定範例
# 複製此檔案為 .env.local 並依照你的環境調整

# ── 幾何核心服務 (OCCT backend) ──
# 預設: http://127.0.0.1:8400/api/v1/geometry
# 生產環境請改為實際伺服器位址
# NEXT_PUBLIC_GEOMETRY_API_URL=http://your-server:8400/api/v1/geometry

# ── Electron 路徑 (開發環境) ──
# 如果 Python 不在預設路徑，請設定
# GEOMETRY_PYTHON_PATH=C:\3D_ENV_FINAL\python.exe
